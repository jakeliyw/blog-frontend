{
    "version": 2,
    "functions": {
        "api/*.js": {
            "runtime": "@vercel/node"
        }
    },
    "rewrites": [
        {
            "source": "/blog-images/:path*",
            "destination": "/api/proxy?path=:path*"
        },
        {
            "source": "/prod-api/:path*",
            "destination": "https://nest-blog-eight.vercel.app/prod-api/:path*"
        }
    ]
}